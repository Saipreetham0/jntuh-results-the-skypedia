# =============================================================================
# JNTUH Results - The Skypedia — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Site URL (used for CSRF origin checks and email links)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://jntuhresults.theskypedia.com

# -----------------------------------------------------------------------------
# Database — MySQL
# -----------------------------------------------------------------------------
DATABASE_URL=mysql://user:password@localhost:3306/jntuh_results

# -----------------------------------------------------------------------------
# Supabase (PostgreSQL + Auth)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -----------------------------------------------------------------------------
# NextAuth
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars

# -----------------------------------------------------------------------------
# Google OAuth (for Calendar sync and Google login)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# -----------------------------------------------------------------------------
# Google AdSense
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-4870864326886980

# -----------------------------------------------------------------------------
# Google Tag Manager
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GTM_ID=GTM-W6TSKNVX

# -----------------------------------------------------------------------------
# Email — Resend (used by contact form)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_your_resend_api_key

# -----------------------------------------------------------------------------
# Email — Brevo / Sendinblue (used by newsletter subscribe)
# -----------------------------------------------------------------------------
BREVO_API_KEY=your-brevo-api-key

# -----------------------------------------------------------------------------
# Redis (optional — for production-scale caching and rate limiting)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
